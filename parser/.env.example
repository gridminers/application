# Copy to .env and fill in the API key.
AZURE_OPENAI_API_KEY=

# Deployment / model name. "gpt-5.4" is a guess; adjust if the endpoint rejects it.
AZURE_OPENAI_MODEL=gpt-5.4

# Endpoint and API version (override only if they change).
AZURE_OPENAI_ENDPOINT=https://internal-use-ai.cognitiveservices.azure.com/openai/responses
AZURE_OPENAI_API_VERSION=2025-04-01-preview

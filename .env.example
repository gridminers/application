# Django
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=backend.settings.prod

# PostgreSQL
POSTGRES_DB=gridminers
POSTGRES_USER=gridminers
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# LLM-Veredelung eingehender Parser-Exporte (Refining/Sanitizing/Enriching).
# Ohne API-Key oder mit LLM_REFINER_ENABLED=false arbeitet der Refiner als
# Passthrough (Verhalten wie bisher).
LLM_REFINER_ENABLED=true
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL=gpt-5.4
AZURE_OPENAI_ENDPOINT=https://internal-use-ai.cognitiveservices.azure.com/openai/responses
AZURE_OPENAI_API_VERSION=2025-04-01-preview
LLM_REFINER_TIMEOUT=60
LLM_REFINER_MAX_RETRIES=3
